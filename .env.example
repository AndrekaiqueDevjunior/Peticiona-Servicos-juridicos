# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================

# DATABASE CONFIGURATION
POSTGRES_DB=peticiona_prod
POSTGRES_USER=peticiona_admin
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://peticiona_admin:CHANGE_THIS_TO_STRONG_PASSWORD@db:5432/peticiona_prod

# FLASK / BACKEND CONFIGURATION
FLASK_SECRET_KEY=GENERATE_WITH: python -c 'import secrets; print(secrets.token_hex(32))'
PASSWORD_SALT=GENERATE_WITH: python -c 'import secrets; print(secrets.token_hex(32))'
FLASK_PORT=5000
FLASK_DEBUG=false
FLASK_ENV=production

# FILE UPLOADS
MAX_UPLOAD_MB=50

# CORS CONFIGURATION (Production URLs)
CORS_ALLOWED_ORIGINS=https://peticiona.com,https://app.peticiona.com,https://www.peticiona.com

# API BASE URLs (for frontend)
NEXT_PUBLIC_API_BASE_URL=https://api.peticiona.com/api
SERVER_API_BASE_URL=http://backend:5000/api

# JWT Configuration (if using JWT tokens)
JWT_SECRET=GENERATE_WITH: python -c 'import secrets; print(secrets.token_hex(32))'
JWT_EXPIRATION=86400

# RATE LIMITING
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# ============================================
# RESEND — Serviço de e-mail (produção)
# ============================================
# Chave de API do Resend (não commitar — obter em https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Endereço de origem dos e-mails (deve ser um domínio verificado no Resend)
# Ex: "Peticiona <no-reply@peticiona.app.br>"  ou apenas  "no-reply@peticiona.app.br"
RESEND_FROM_EMAIL=no-reply@peticiona.app.br

# Endereço administrativo que recebe as mensagens do formulário de contato
RESEND_CONTACT_TO_EMAIL=contato@peticiona.app.br

# Segredo HMAC para validar webhooks do Resend (obter em Resend Dashboard > Webhooks)
# Formato: whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# URLs públicas (usadas em links de e-mail)
# ============================================
# URL pública do frontend (usada no link de redefinição de senha)
FRONTEND_PUBLIC_URL=https://peticiona.app.br
FRONTEND_URL=https://peticiona.app.br

# URL pública do backend (opcional, para referências internas)
BACKEND_PUBLIC_URL=https://api.peticiona.app.br

# ============================================
# RESET DE SENHA
# ============================================
# Tempo de expiração do token de redefinição em segundos (padrão: 3600 = 1h)
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# ============================================
# EMAIL LEGADO (SendGrid / SMTP — fallback)
# Se RESEND_API_KEY estiver configurado, estes são ignorados.
# ============================================
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM=no-reply@peticiona.app.br
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true
