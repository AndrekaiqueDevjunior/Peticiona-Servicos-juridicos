# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================

# DATABASE CONFIGURATION
POSTGRES_DB=peticiona_prod
POSTGRES_USER=peticiona_admin
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://peticiona_admin:CHANGE_THIS_TO_STRONG_PASSWORD@db:5432/peticiona_prod

# FLASK / BACKEND CONFIGURATION
FLASK_SECRET_KEY=GENERATE_WITH: python -c 'import secrets; print(secrets.token_hex(32))'
PASSWORD_SALT=GENERATE_WITH: python -c 'import secrets; print(secrets.token_hex(32))'
FLASK_PORT=5000
FLASK_DEBUG=false
FLASK_ENV=production

# FILE UPLOADS
MAX_UPLOAD_MB=50

# CORS CONFIGURATION (Production URLs)
CORS_ALLOWED_ORIGINS=https://peticiona.com,https://app.peticiona.com,https://www.peticiona.com

# API BASE URLs (for frontend)
NEXT_PUBLIC_API_BASE_URL=https://api.peticiona.com/api
SERVER_API_BASE_URL=http://backend:5000/api

# JWT Configuration (if using JWT tokens)
JWT_SECRET=GENERATE_WITH: python -c 'import secrets; print(secrets.token_hex(32))'
JWT_EXPIRATION=86400

# RATE LIMITING
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
